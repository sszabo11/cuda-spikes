	$(MAKE) $(MAKESILENT) -f CMakeFiles/snn_c.dir/build.make CMakeFiles/snn_c.dir/src/foo.c.o
	$(MAKE) $(MAKESILENT) -f CMakeFiles/foo.dir/build.make CMakeFiles/foo.dir/src/foo.c.o
.PHONY : src/foo.c.o

